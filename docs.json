{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "Specter",
  "colors": {
    "primary": "#54545c"
  },
  "favicon": "https://icons.duckduckgo.com/ip3/starter.mintlify.com.ico",
  "logo": {
    "light": "https://media.brand.dev/99d23bb0-7527-48e5-b2c1-71011df3a4d8.svg",
    "dark": "https://media.brand.dev/99d23bb0-7527-48e5-b2c1-71011df3a4d8.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:azher@tryspecter.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://app.tryspecter.com"
    }
  },
  "contextual": {
    "options": [
      "claude",
      "copy",
      "view",
      "chatgpt",
      "perplexity"
    ]
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true
  },
